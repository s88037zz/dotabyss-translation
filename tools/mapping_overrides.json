      "dialogue": { "dict": "m_tavern_dialogue" }
    },
    "MAbilityDetails": {
      "description": { "dict": "m_ability_details", "seal": true },
      "awake_description": { "dict": "m_ability_details", "seal": true }
    },
    "MCharacterActionSkills": {
      "description": { "dict": "m_character_action_skills", "seal": true }
    },
    "MChapterQuests": {
      "name": [
        { "dict": "m_chapter_quests" },
        { "dict": "m_chapter_quests" }
      ]
    }
  },
  "dict_seal_fields": {
    "m_ability_details": ["description", "awake_description"],
    "m_character_action_skills": ["description"]
